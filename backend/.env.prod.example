# ============================================================
# Aus Auto Parts — PRODUCTION Environment Template
# ============================================================
# Copy this to backend/.env.prod and fill in all values.
# NEVER commit .env.prod to version control.
# ============================================================

NODE_ENV=production
PORT=3000

# ---- Database -----------------------------------------------
# Managed by docker-compose.prod.yml — set these at compose level.
# These are for direct prisma CLI use (migrations, studio).
DATABASE_URL="postgresql://CHANGE_ME_USER:CHANGE_ME_PASS@localhost:5432/aus_auto_parts_prod?schema=public"

POSTGRES_USER=CHANGE_ME_USER
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD_32CHARS
POSTGRES_DB=aus_auto_parts_prod

# ---- Redis --------------------------------------------------
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=CHANGE_ME_REDIS_PASSWORD_24CHARS
REDIS_DB=0
REDIS_TLS=false

# ---- JWT ----------------------------------------------------
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_SECRET
JWT_REFRESH_SECRET=CHANGE_ME_64_CHAR_HEX_REFRESH_SECRET
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d
JWT_EMAIL_VERIFICATION_EXPIRY=24h
JWT_PASSWORD_RESET_EXPIRY=1h
JWT_ISSUER=aus-auto-parts-platform

# ---- CORS ---------------------------------------------------
# Your production domain(s) — no trailing slash
ALLOWED_ORIGINS=https://your-domain.com.au
CORS_CREDENTIALS=true

# ---- Rate Limiting ------------------------------------------
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_BASIC=1000
RATE_LIMIT_MAX_PRO=10000
RATE_LIMIT_MAX_ENTERPRISE=100000

# ---- Security -----------------------------------------------
BCRYPT_ROUNDS=12
SESSION_SECRET=CHANGE_ME_SESSION_SECRET_32CHARS

# ---- Logging ------------------------------------------------
LOG_LEVEL=warn
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_ERROR_FILE_PATH=logs/error.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# ---- API ----------------------------------------------------
API_PREFIX=/api/v1
API_TIMEOUT=30000

# ---- File Upload --------------------------------------------
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# ---- Email (configure when ready) --------------------------
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=true
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@your-domain.com.au

# ---- AWS S3 (configure when ready) -------------------------
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# ---- Monitoring (configure when ready) ---------------------
SENTRY_DSN=
