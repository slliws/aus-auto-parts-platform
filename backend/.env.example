# Application Environment
# Controls application behavior (development, test, production)
NODE_ENV=development
# Port the API server will listen on
PORT=3000

# Database Configuration (Prisma)
# Format: postgresql://[username]:[password]@[host]:[port]/[database_name]?schema=[schema]
# Example for local development:
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/auto_parts_platform?schema=public"
# Example for Docker:
# DATABASE_URL="postgresql://postgres:postgres@postgres:5432/auto_parts_platform?schema=public"

# Legacy Database Configuration (for reference only - Prisma uses DATABASE_URL above)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=auto_parts_platform
DB_USER=postgres
DB_PASSWORD=postgres
DB_SSL=false
DB_MAX_CONNECTIONS=20
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=2000

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0
REDIS_TLS=false

# JWT Configuration
# CRITICAL: Change these secrets in production environments!
JWT_SECRET=your-secret-key-change-in-production
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_ACCESS_EXPIRY=1h
JWT_REFRESH_EXPIRY=30d
JWT_EMAIL_VERIFICATION_EXPIRY=24h
JWT_PASSWORD_RESET_EXPIRY=1h
JWT_ISSUER=aus-auto-parts-platform

# Rate Limiting Configuration
RATE_LIMIT_WINDOW_MS=3600000
RATE_LIMIT_MAX_BASIC=1000
RATE_LIMIT_MAX_PRO=10000
RATE_LIMIT_MAX_ENTERPRISE=100000

# CORS Configuration
# Add your frontend URLs here (comma separated)
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3001,http://localhost:3000
CORS_CREDENTIALS=true

# Logging Configuration
LOG_LEVEL=debug
LOG_FORMAT=json
LOG_FILE_PATH=logs/app.log
LOG_ERROR_FILE_PATH=logs/error.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=14d

# Security
BCRYPT_ROUNDS=12
SESSION_SECRET=your-session-secret-change-in-production

# API Configuration
API_PREFIX=/api/v1
API_TIMEOUT=30000

# File Upload (future)
MAX_FILE_SIZE=10485760
UPLOAD_PATH=uploads/

# Email (future)
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASSWORD=
EMAIL_FROM=noreply@aus-auto-parts.com

# AWS Configuration (future)
AWS_REGION=ap-southeast-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_BUCKET=

# Monitoring (future)
SENTRY_DSN=
NEW_RELIC_LICENSE_KEY=